//- productForm.pug
html(lang="pt-BR")
  head
    meta(charset="UTF-8")
    title #{title}
  body
    h1 #{title}
    form(action=action method="post")
      label(for="name") Nome:
      input(type="text" name="name" id="name" required value=product?.name)
      br
      label(for="price") Preço:
      input(type="number" step="0.01" name="price" id="price" required value=product?.price)
      br
      button(type="submit") Salvar
    a(href="/products") Voltar
    footer
      p © #{new Date().getFullYear()} - CRUD Aula 12
